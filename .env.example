# Document analysis: set ONE of these (script prefers Claude – no rate-limit hassle)
# Easiest: get a key at https://console.anthropic.com → API keys
# ANTHROPIC_API_KEY=your_anthropic_api_key

# Or use Gemini (can hit free-tier rate limits):
# GEMINI_API_KEY=your_gemini_api_key

# Optional: path to folder containing PDF/PPTX/XLSX docs (default: ./docs)
# DOCS_PATH=./docs
