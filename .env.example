# Document analysis: set ONE of these (script prefers Claude – no rate-limit hassle)
# Easiest: get a key at https://console.anthropic.com → API keys
# ANTHROPIC_API_KEY=your_anthropic_api_key

# Or use Gemini (can hit free-tier rate limits):
# GEMINI_API_KEY=your_gemini_api_key

# Optional: path to folder containing PDF/PPTX/XLSX docs (default: ./docs)
# DOCS_PATH=./docs

# Market Reality imagery: npm run generate-market-reality-images uses ANTHROPIC_API_KEY
# to generate image prompts and Pexels/Unsplash search terms. Optional: GEMINI_API_KEY
# for future image generation (e.g. Imagen) if added to the script.
